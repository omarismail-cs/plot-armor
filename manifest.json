{
  "manifest_version": 3,
  "name": "Plot Armor",
  "version": "0.1.0",
  "description": "AI-powered spoiler blocker (starter scaffold).",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://api.openai.com/*", "https://api.themoviedb.org/*", "https://en.wikipedia.org/*"],
  "action": {
    "default_title": "Plot Armor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
